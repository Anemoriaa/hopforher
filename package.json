{
  "name": "giftsher-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @giftsher/web",
    "dev:web": "npm run dev -w @giftsher/web",
    "dev:admin": "npm run dev -w @giftsher/admin",
    "build": "npm run build -w @giftsher/web",
    "build:web": "npm run build -w @giftsher/web",
    "build:admin": "npm run build -w @giftsher/admin",
    "preview": "npm run preview -w @giftsher/web",
    "preview:web": "npm run preview -w @giftsher/web",
    "preview:admin": "npm run preview -w @giftsher/admin",
    "start": "npm run dev"
  }
}
