{
  "name": "shopforher-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @shopforher/web",
    "dev:web": "npm run dev -w @shopforher/web",
    "dev:admin": "npm run dev -w @shopforher/admin",
    "build": "npm run build -w @shopforher/web",
    "build:web": "npm run build -w @shopforher/web",
    "build:admin": "npm run build -w @shopforher/admin",
    "seo:ops": "node ./apps/web/scripts/seo-ops-report.mjs",
    "preview": "npm run preview -w @shopforher/web",
    "preview:web": "npm run preview -w @shopforher/web",
    "preview:admin": "npm run preview -w @shopforher/admin",
    "test:smoke": "node --test tests/smoke/*.test.mjs",
    "start": "npm run dev"
  }
}
